<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
  <!-- Mapping/Serialization layers can be chatty with chaining -->
  <suppress files=".*/adapter-in-.*" checks="RegexpSinglelineJava"/>
  <suppress files=".*/adapter-out-.*" checks="RegexpSinglelineJava"/>
  <suppress files=".*Mapper\.java" checks="RegexpSinglelineJava"/>

  <!-- Test source sets: allow star imports (AssertJ, JUnit) -->
  <suppress files=".*[\\/]src[\\/]test[\\/].*" checks="AvoidStarImport"/>
  <suppress files=".*[\\/]src[\\/]testFixtures[\\/].*" checks="AvoidStarImport"/>

  <!-- QueryDSL generated Q* classes -->
  <suppress files=".*[\\/]build[\\/]generated[\\/].*" checks=".*"/>
</suppressions>